# Copy this file to .env and fill in your keys. NEVER commit .env to git.

# ── LLM (generator + critic) ────────────────────────────────────────────────
# Pick a provider: openai | groq | google | anthropic
LLM_PROVIDER=groq
# Leave LLM_MODEL blank to use the provider's default
# (groq -> llama-3.3-70b-versatile, openai -> gpt-4o-mini, google -> gemini-1.5-flash).
LLM_MODEL=

# Set ONLY the key for the provider you chose:
GROQ_API_KEY=your_groq_key_here          # free, no card: https://console.groq.com/keys
# OPENAI_API_KEY=your_openai_key_here     # needs billing at platform.openai.com
# GOOGLE_API_KEY=your_google_key_here     # free tier: https://aistudio.google.com/apikey
# ANTHROPIC_API_KEY=your_anthropic_key_here

# ── Reranking (free tier at cohere.com) ─────────────────────────────────────
COHERE_API_KEY=your_cohere_key_here
RERANK_MODEL=rerank-english-v3.0

# ── Embeddings (runs locally, no key needed) ────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIM=384

# ── Vector store (local Docker — no key needed) ─────────────────────────────
QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=                  # only needed for Qdrant Cloud
QDRANT_COLLECTION=documents

# ── Retrieval / self-heal tuning ────────────────────────────────────────────
RETRIEVE_TOP_K=10
RERANK_TOP_N=4
MAX_RETRIES=2
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# ── Observability (free tier at smith.langchain.com) ────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_key_here
LANGCHAIN_PROJECT=self-healing-rag
